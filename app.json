{
  "expo": {
    "name": "ProEstoque",
    "slug": "proestoque",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "proestoque",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "plugins": ["expo-router"],
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#f8fafc"
    },
    "experiments": {
      "typedRoutes": true
    },
    "android": {
      "package": "com.livianmendes.proestoque",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#7c3aed"
      }
    },
    "ios": {
      "bundleIdentifier": "com.livianmendes.proestoque",
      "buildNumber": "1",
      "supportsTablet": false
    }
  }
}
